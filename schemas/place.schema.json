{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Altera Place",
  "description": "A canonical skiable location in the Altera platform",
  "type": "object",
  "properties": {
    "country_code": {
      "type": "string",
      "pattern": "^[a-z]{2}$"
    },
    "region_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "place_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "description": "Canonical English name. The root of the fallback chain when no name_i18n match exists."
    },
    "name_i18n": {
      "type": "object",
      "description": "Locale-keyed display names. Keys are ISO 639-1 language codes (e.g. ko, en, ja). Matches the LocalizedText shape in paulkim-xr/SkiWatch.",
      "patternProperties": {
        "^[a-z]{2}$": { "type": "string" }
      },
      "additionalProperties": false
    },
    "region": {
      "type": "string"
    },
    "region_i18n": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{2}$": { "type": "string" }
      },
      "additionalProperties": false
    },
    "country": {
      "type": "string"
    },
    "country_i18n": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{2}$": { "type": "string" }
      },
      "additionalProperties": false
    },
    "coordinates": {
      "type": "object",
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      },
      "required": ["latitude", "longitude"]
    },
    "elevations": {
      "type": "object",
      "properties": {
        "base_m": { "type": "integer" },
        "summit_m": { "type": "integer" }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["country_code", "region_slug", "place_slug", "name", "coordinates"]
}
