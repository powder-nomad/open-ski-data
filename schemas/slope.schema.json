{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Altera Slopes Registry",
  "type": "object",
  "properties": {
    "resort_slug": { "type": "string" },
    "slopes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "localized_name": {
            "type": "object",
            "properties": {
              "ko": { "type": "string" },
              "en": { "type": "string" },
              "ja": { "type": "string" }
            }
          },
          "type": { "enum": ["run", "lift", "access_route", "terrain_park"] },
          "difficulty": { "enum": ["beginner", "intermediate", "advanced", "expert", "pro", "park"] },
          "length_m": { "type": ["number", "null"] },
          "width_m": { "type": ["number", "null"] },
          "area_m2": { "type": ["number", "null"] },
          "elevation_drop_m": { "type": ["number", "null"] },
          "min_angle_deg": { "type": ["number", "null"] },
          "avg_angle_deg": { "type": ["number", "null"] },
          "max_angle_deg": { "type": ["number", "null"] },
          "connected_slope_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "connected_lift_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "coordinates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lon": { "type": "number" }
              }
            }
          }
        },
        "required": ["id", "name", "type"]
      }
    }
  },
  "required": ["resort_slug", "slopes"]
}
