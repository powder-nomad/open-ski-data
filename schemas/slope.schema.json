{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Altera Slopes Registry",
  "type": "object",
  "properties": {
    "country_code": {
      "type": "string",
      "pattern": "^[a-z]{2}$"
    },
    "region_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "place_slug": { "type": "string" },
    "slopes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Stable identifier. Historically strings; SkiWatch source uses integers, so both are accepted.",
            "type": ["string", "integer"]
          },
          "name": { "type": "string" },
          "name_i18n": {
            "type": "object",
            "description": "Locale-keyed names matching SkiWatch's LocalizedText shape.",
            "patternProperties": { "^[a-z]{2}$": { "type": "string" } },
            "additionalProperties": false
          },
          "type": { "enum": ["run", "lift", "access_route"] },
          "difficulty": {
            "description": "Covers SkiWatch's finer-grained levels (be_in / in_ad) and `park` so nothing is lost on import.",
            "enum": [
              "beginner",
              "be_in",
              "intermediate",
              "in_ad",
              "advanced",
              "expert",
              "pro",
              "park"
            ]
          },
          "length_m": { "type": ["number", "null"] },
          "width_m": { "type": ["number", "null"] },
          "area_m2": { "type": ["number", "null"] },
          "elevation_m": { "type": ["number", "null"] },
          "min_angle_deg": { "type": ["number", "null"] },
          "avg_angle_deg": { "type": ["number", "null"] },
          "max_angle_deg": { "type": ["number", "null"] },
          "connected_slope_ids": {
            "type": "array",
            "items": { "type": ["string", "integer"] }
          },
          "connected_lift_ids": {
            "type": "array",
            "items": { "type": ["string", "integer"] }
          },
          "coordinates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lon": { "type": "number" }
              }
            }
          }
        },
        "required": ["id", "name"]
      }
    }
  },
  "required": ["country_code", "region_slug", "place_slug", "slopes"]
}
