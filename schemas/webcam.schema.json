{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Altera Webcam Registry",
  "type": "object",
  "properties": {
    "country_code": {
      "type": "string",
      "pattern": "^[a-z]{2}$"
    },
    "region_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "place_slug": { "type": "string" },
    "webcams": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "label_i18n": {
            "type": "object",
            "description": "Locale-keyed labels — SkiWatch's streams.ts carries { ko, en, ja } on every entry.",
            "patternProperties": { "^[a-z]{2}$": { "type": "string" } },
            "additionalProperties": false
          },
          "url": { "type": "string", "format": "uri" },
          "type": {
            "enum": [
              "image",
              "stream",
              "hls",
              "iframe",
              "external",
              "unavailable",
              "vivaldi"
            ]
          },
          "refresh_interval_ms": { "type": "integer" }
        },
        "required": ["label", "url", "type"]
      }
    }
  },
  "required": ["country_code", "region_slug", "place_slug", "webcams"]
}
